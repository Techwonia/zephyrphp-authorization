{
    "name": "zephyrphp/authorization",
    "description": "Authorization module for ZephyrPHP - Gates and Policies",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "zephyrphp/framework": "^0.1|^0.2|^0.3|^1.0|dev-main",
        "zephyrphp/auth": "^0.1|dev-main"
    },
    "autoload": {
        "psr-4": {
            "Zephyr\\Authorization\\": "src/"
        }
    },
    "extra": {
        "zephyr": {
            "module": "authorization",
            "dependencies": ["auth"]
        }
    }
}
